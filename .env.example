# Public URL of your app (used in generated links sent via email)
BASE_URL=https://songguesser.example.com

# Timezone for deadline enforcement — must match the timezone used when setting deadlines
# Examples: Europe/Berlin, Europe/London, America/New_York
TZ=Europe/Berlin

# SMTP configuration
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_SSL=false
SMTP_USER=songguesser@example.com
SMTP_PASS=your-password
SMTP_FROM=Song Guesser <songguesser@example.com>

# SQLite database path (inside container)
DATABASE_URL=sqlite:////app/data/songguesser.db

# Traefik configuration
TRAEFIK_NETWORK=traefik
APP_HOSTNAME=songguesser.example.com
