# Local development — no Traefik, no real domain, email optional
BASE_URL=http://localhost

# Leave SMTP empty to disable emails locally (the app still works)
SMTP_HOST=
SMTP_PORT=587
SMTP_SSL=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

DATABASE_URL=sqlite:////app/data/songguesser.db

# Must match your local timezone so deadline comparisons work correctly
TZ=Europe/Berlin
